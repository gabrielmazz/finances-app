EXPO_PUBLIC_FIREBASE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=xxxxxxx.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=xxxxxxxx
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=xxxxxxxx.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxx
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Chave pública do site reCAPTCHA Enterprise usada pelo App Check no Web.
# Não é uma chave da API Gemini.
EXPO_PUBLIC_FIREBASE_APP_CHECK_RECAPTCHA_ENTERPRISE_KEY=6Ledn1wtAAAAACA-UYUtlbCIbsfrfEjIstLfS34R

# Apenas desenvolvimento Android. Cadastre o token no console do App Check.
EXPO_PUBLIC_FIREBASE_APP_CHECK_DEBUG_TOKEN=

# Use debug somente em development/preview. Produção usa Play Integrity por padrão.
EXPO_PUBLIC_FIREBASE_APP_CHECK_ANDROID_PROVIDER=debug

# Caminho para uma variável de arquivo do EAS ou para um arquivo local ignorado pelo Git.
GOOGLE_SERVICES_JSON=
